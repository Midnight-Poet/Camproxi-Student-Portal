{
  "version": 2,
  "builds": [
    {
      "src": "/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/(.*\\.(?:ico|png|jpg|jpeg|svg|gif|webp|json|txt|webmanifest))", "dest": "/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}